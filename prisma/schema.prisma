// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MaterialRole {
  MAIN_MATERIAL
  SUPPORT_MATERIAL
  MIXED_MATERIAL
  UNKNOWN
}

model User {
  id                     String              @id @default(cuid())
  name                   String?
  email                  String?             @unique
  passwordHash           String?
  authUserId             String?             @unique
  lastLoginAt            DateTime?
  googleAccountConnected Boolean             @default(false)
  googleAccessToken      String?
  googleRefreshToken     String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  


  preferences            UserPreferences?

  subjects               StudySubject[]
  studyPlans             StudyPlan[]
  flashcards             Flashcard[]
  materials              StudyMaterial[]
  extractedContent       ExtractedContent[]
  studyBlocks            StudyBlock[]
  studySchedules         StudySchedule[]
  studyScheduleItems     StudyScheduleItem[]
}

model UserPreferences {
  id                          String   @id @default(cuid())
  userId                      String   @unique
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dailyGoalMinutes            Int      @default(120)
  studyResetTime              String   @default("00:00")
  studyDaysOfWeek             String   @default("1,2,3,4,5")
  defaultBlockDurationMinutes Int      @default(30)
  maxNewCardsPerDay           Int      @default(20)
  flashcardDifficulty         String   @default("NORMAL_PLUS")
  emailReminderEnabled        Boolean  @default(true)
  emailReminderTime           String   @default("08:00")
  dailyReminderEmail          String?
  lastDailyReminderSentAt     DateTime?
  visualDensity               String   @default("comfortable")
  reducedMotion               Boolean  @default(false)
  focusArea                   String   @default("Geral")
  theme                       String   @default("light")
  displayName                 String   @default("Estudante")
  examGoal                    String   @default("TRT4")
  deadline                    DateTime?
  avatarUrl                   String?
  languageTone                String   @default("MASCULINE_NEUTRAL")
  
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model StudySubject {
  id               String              @id @default(cuid())
  name             String
  description      String?
  priority         Int                 @default(1)
  examWeight       Float               @default(1.0)
  progress         Float               @default(0)
  studyPriority    String              @default("PRIMARY")
  userId           String
  user             User                @relation(fields: [userId], references: [id])
  materials        StudyMaterial[]
  flashcards       Flashcard[]
  studyPlanDays    StudyPlanDay[]
  extractedContent ExtractedContent[]
  studyBlocks      StudyBlock[]
  schedules        StudySchedule[]
  scheduleItems    StudyScheduleItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model StudyMaterial {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id])
  fileName           String
  originalFileName   String?
  filePath           String?
  googleDriveFileId  String?
  mimeType           String              @default("application/pdf")
  fileSize           Int?
  totalPages         Int?
  
  // New fields for the intelligent organizer
  sourceType         String              @default("LOCAL_UPLOAD") // LOCAL_UPLOAD, LOCAL_INBOX
  sourcePath         String?
  fileHash           String?
  organizationStatus String              @default("UPLOADED") // UPLOADED, IMPORTED, EXTRACTING, ANALYZING, ORGANIZED, NEEDS_REVIEW, ERROR
  detectedSubjectName String?
  detectedStructure  String?             // JSON string for structure
  
  processingStatus   String              @default("PENDING") // PENDING, PROCESSING, PROCESSED, ERROR
  processingError    String?
  subjectId          String?
  subject            StudySubject?       @relation(fields: [subjectId], references: [id])
  materialRole       MaterialRole        @default(UNKNOWN)
  supportForTopicId  String?
  supportedBlocks    StudyBlockSupport[]
  extractedContent   ExtractedContent[]
  studyBlocks        StudyBlock[]
  flashcards         Flashcard[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studyScheduleItems StudyScheduleItem[]
}

model ExtractedContent {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id])
  subjectId             String
  subject               StudySubject   @relation(fields: [subjectId], references: [id])
  title                 String?
  pageNumber            Int
  text                  String
  orderIndex            Int
  estimatedStudyMinutes Int?
  materialId            String
  material              StudyMaterial  @relation(fields: [materialId], references: [id])
  studyPlanDays         StudyPlanDay[]
  flashcards            Flashcard[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model StudyPlan {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  estimatedExamDate DateTime?
  dailyStudyMinutes Int            @default(120)
  availableWeekDays String         @default("1,2,3,4,5") // 0=Sun, 1=Mon, etc.
  status            String         @default("ACTIVE")
  days              StudyPlanDay[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model StudyPlanDay {
  id            String           @id @default(cuid())
  studyPlanId   String
  studyPlan     StudyPlan        @relation(fields: [studyPlanId], references: [id])
  dayNumber     Int
  scheduledDate DateTime
  subjectId     String
  subject       StudySubject     @relation(fields: [subjectId], references: [id])
  contentId     String
  content       ExtractedContent @relation(fields: [contentId], references: [id])
  status        String           @default("PENDING") // PENDING, COMPLETED, SKIPPED
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Flashcard {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  subjectId    String
  subject      StudySubject      @relation(fields: [subjectId], references: [id])
  contentId    String?
  content      ExtractedContent? @relation(fields: [contentId], references: [id])
  materialId   String?
  material     StudyMaterial?    @relation(fields: [materialId], references: [id], onDelete: SetNull)
  studyBlockId String?
  studyBlock   StudyBlock?       @relation(fields: [studyBlockId], references: [id], onDelete: SetNull)

  question     String
  answer       String
  type         String @default("QUESTION_ANSWER") // QUESTION_ANSWER, CLOZE
  difficulty   String @default("MEDIUM") // EASY, MEDIUM, HARD
  status       String @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, ARCHIVED
  
  // SRS (Anki-style)
  reviewState     String?   @default("NEW") // NEW, LEARNING, REVIEW, RELEARNING, SUSPENDED
  learningStep    Int?      @default(0)
  easeFactor      Float?    @default(2.5)
  intervalDays    Int?      @default(0)
  repetitionCount Int?      @default(0)
  lapseCount      Int?      @default(0)
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime? @default(now())
  approvedAt      DateTime?

  sourcePageStart Int?
  sourcePageEnd   Int?

  reviews         FlashcardReview[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, nextReviewAt])
  @@index([userId, reviewState])
}

model FlashcardReview {
  id                 String    @id @default(cuid())
  flashcardId        String
  flashcard          Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  userId             String
  rating             Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  reviewedAt         DateTime  @default(now())
  
  previousState      String
  newState           String
  previousInterval   Int
  newInterval        Int
  previousEaseFactor Float
  newEaseFactor      Float
  previousNextReviewAt DateTime
  newNextReviewAt      DateTime
}

model StudyNote {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyBlock {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  subjectId  String
  subject    StudySubject  @relation(fields: [subjectId], references: [id])
  materialId String
  material   StudyMaterial @relation(fields: [materialId], references: [id])

  title                 String
  description           String?
  pageStart             Int
  pageEnd               Int
  orderIndex            Int     @default(0)
  estimatedStudyMinutes Int?
  status                String  @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, SKIPPED

  // AI organization metadata
  createdBy             String  @default("MANUAL") // MANUAL, AI
  sourceHeading         String?
  sourceSection         String?
  officialTopicId       String?
  officialTopicName     String?
  topicCode             String?
  confidence            Float?

  // Study cycle lifecycle
  theoryStatus          String    @default("NOT_STARTED") // NOT_STARTED | COMPLETED
  questionsStatus       String    @default("NOT_STARTED") // NOT_STARTED | COMPLETED
  flashcardsStatus      String    @default("NOT_STARTED") // NOT_STARTED | GENERATED

  theoryCompletedAt     DateTime?
  questionsCompletedAt  DateTime?
  flashcardsGeneratedAt DateTime?

  // Spaced repetition block reviews
  review1dScheduledAt   DateTime?
  review7dScheduledAt   DateTime?
  review15dScheduledAt  DateTime?
  review30dScheduledAt  DateTime?

  review1dCompletedAt   DateTime?
  review7dCompletedAt   DateTime?
  review15dCompletedAt  DateTime?
  review30dCompletedAt  DateTime?

  lastStudiedAt         DateTime?
  nextActionType        String?   // THEORY | QUESTIONS | GENERATE_FLASHCARDS | REVIEW_BLOCK | REINFORCEMENT
  nextActionAt          DateTime?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  flashcards    Flashcard[]
  scheduleItems StudyScheduleItem[]
  supportMaterials StudyBlockSupport[]

  @@index([userId, status])
}

model StudyBlockSupport {
  id           String        @id @default(cuid())
  studyBlockId String
  studyBlock   StudyBlock    @relation(fields: [studyBlockId], references: [id], onDelete: Cascade)
  materialId   String
  material     StudyMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  pageStart    Int?
  pageEnd      Int?
  supportType  String?       // BIZU, MAPA_MENTAL, RESUMO, REVISAO, QUESTOES
  confidence   Float?
  createdAt    DateTime      @default(now())
}

model StudySchedule {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  title             String
  startDate         DateTime            @default(now())
  estimatedExamDate DateTime?
  dailyStudyMinutes Int                 @default(60)
  status            String              @default("ACTIVE") // ACTIVE, COMPLETED, ARCHIVED
  items             StudyScheduleItem[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  studySubject      StudySubject?       @relation(fields: [studySubjectId], references: [id])
  studySubjectId    String?
}

model StudyScheduleItem {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  scheduleId       String
  schedule         StudySchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          StudySubject   @relation(fields: [subjectId], references: [id])
  materialId       String?
  material         StudyMaterial? @relation(fields: [materialId], references: [id])
  studyBlockId     String?
  studyBlock       StudyBlock?    @relation(fields: [studyBlockId], references: [id], onDelete: Cascade)

  // Action metadata (new)
  actionType       String?        // THEORY | QUESTIONS | GENERATE_FLASHCARDS | REVIEW_BLOCK | REVIEW_FLASHCARDS | REINFORCEMENT
  priorityScore    Float?
  reason           String?

  dayNumber        Int
  scheduledDate    DateTime?
  estimatedMinutes Int?
  status           String         @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  completedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userId, scheduledDate, status])
  @@index([userId, scheduleId, status])
}
